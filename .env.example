# ============================================================
# Environment Variables — HFT Execution Framework
# Copy to .env and fill in your actual values
# ============================================================

# Telegram Bot (for trade alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Zerodha Kite Connect (live trading — leave blank for paper mode)
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=
ZERODHA_PAPER_MODE=true

# NSE India API (for live data feed — no key needed, rate-limited)
NSE_BASE_URL=https://www.nseindia.com

# Database (TimescaleDB optional — SQLite used by default)
DATABASE_URL=sqlite:///./hft-strategies/tick_database.db
# DATABASE_URL=postgresql://user:password@localhost:5432/hft_ticks

# Risk Limits (override in live_config.json)
RISK_MAX_DAILY_LOSS=100000
RISK_MAX_NET_DELTA=200
RISK_MAX_GROSS=500

# Logging
LOG_LEVEL=INFO
